APP_NAME=AttendanceManagement
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ────────────────────────────────────────────────────────────────────────────────
# Attendance Database Connection
# ────────────────────────────────────────────────────────────────────────────────
# DB_CONNECTION=mysql
# DB_HOST=attendance-db
# DB_PORT=3306
# DB_DATABASE=attendancedb
# DB_USERNAME=attuser
# DB_PASSWORD=admin123

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=backend
DB_USERNAME=root
DB_PASSWORD=

# ────────────────────────────────────────────────────────────────────────────────
# This is how AM connects to EM
# ────────────────────────────────────────────────────────────────────────────────
EMPLOYEE_API_URL=http://employee-management:8001/api/employees

# Optional: For Laravel HTTP Client timeout
EMPLOYEE_API_TIMEOUT=5

# ────────────────────────────────────────────────────────────────────────────────
# Session / Cache / Redis / Mail / Queue
# ────────────────────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

VITE_APP_NAME="${APP_NAME}"
